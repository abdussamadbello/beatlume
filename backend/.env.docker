# Docker-compose overrides. Loaded after .env, so these values win inside containers.
# Contains only service hostnames, not secrets — safe to commit (see !.env.docker in .gitignore).

DATABASE_URL=postgresql+asyncpg://beatlume:beatlume_dev@postgres:5432/beatlume
DATABASE_URL_SYNC=postgresql://beatlume:beatlume_dev@postgres:5432/beatlume
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://minio:9000
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PYTHONPATH=/app
